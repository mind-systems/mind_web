# Dependencies (keep build context small; also prevents COPY . . from
# overwriting the in-image npm ci result, including the SSH-cloned observe-js)
node_modules/
node_modules/.cache

# Build output
dist/
dist-ssr/
.vite/

# Environment (exclude host .env.local so it cannot shadow the VITE_API_BASE_URL ARG)
.env.local
.env.*.local
*.local

# Git
.git/
.gitignore

# AI / tooling
.ai-factory/
.playwright-mcp/
.vscode/
.idea/

# Logs & temp
*.log
logs/
*.tmp
*.bak
*.tsbuildinfo

# OS
.DS_Store
Thumbs.db
*.swp
*.swo
